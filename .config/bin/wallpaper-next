#!/bin/bash

WALLPAPER_DIR="$HOME/Pictures/wallpapers"
STATE_FILE="$HOME/.cache/current_wallpaper_index"

# Собираем все обои в массив
mapfile -t wallpapers < <(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.png" -o -iname "*.jpeg" \) | sort)

# Проверяем, есть ли обои
if [ ${#wallpapers[@]} -eq 0 ]; then
    notify-send "Ошибка" "Нет обоев в $WALLPAPER_DIR"
    exit 1
fi

# Читаем текущий индекс (0 если файла нет)
if [ -f "$STATE_FILE" ]; then
    current_index=$(cat "$STATE_FILE")
else
    current_index=0
fi

# Вычисляем следующий индекс (зацикливаем)
next_index=$(( (current_index + 1) % ${#wallpapers[@]} ))

# Берём следующие обои
next_wallpaper="${wallpapers[$next_index]}"

# Меняем обои
pkill swaybg 2>/dev/null
swaybg -o "*" -i "$next_wallpaper" -m fill &

# Сохраняем новый индекс
echo "$next_index" > "$STATE_FILE"

# Уведомление
notify-send "Обои изменены" "$(basename "$next_wallpaper")"
